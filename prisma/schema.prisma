datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String      @id @default(uuid())
  steamId          String?     @unique              
  googleId         String?     @unique              
  username         String
  avatarUrl        String?                          
  balance          Float       @default(150.00) // Стартові 150 балів бета-тесту      
  role             String      @default("USER")     
  nonce            Int         @default(0)      // Кількість відкритих кейсів
  contractsCount   Int         @default(0)      // Кількість створених контрактів
  tradeUrl         String?                      // Посилання на обмін Steam
  lastDailyCaseAt  DateTime?
  createdAt        DateTime    @default(now())
  
  inventory        Inventory[]
  activatedPromos  PromoActivation[]
}

model Case {
  id        String   @id 
  title     String
  price     Float
  category  String   @default("COMMON")
  imageUrl  String?  
  createdAt DateTime @default(now())
  items     Item[]
}

model Item {
  id        String   @id @default(uuid())
  name      String   
  price     Float
  chance    Float    
  imageUrl  String?  
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  droppedIn Inventory[]
}

model Inventory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  droppedAt DateTime @default(now())
  status    String   @default("IN_INVENTORY") 
}

// Нова модель для створення промокодів (наприклад, WELCOME5)
model PromoCode {
  id          String            @id @default(uuid())
  code        String            @unique
  reward      Float             // Скільки балів нараховує (наприклад, 50.0)
  maxUses     Int               @default(100) // Ліміт активацій загалом
  createdAt   DateTime          @default(now())
  activations PromoActivation[]
}

// Модель для відслідковування, хто які коди вже активував, щоб не абузили
model PromoActivation {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoId     String
  promo       PromoCode @relation(fields: [promoId], references: [id], onDelete: Cascade)
  activatedAt DateTime  @default(now())

  @@unique([userId, promoId]) // Один юзер — один промокод
}